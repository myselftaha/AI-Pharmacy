# AI Pharmacy - Environment Variables Template

# ===== Gmail SMTP Configuration =====
# Follow these steps to set up Gmail:
# 1. Go to https://myaccount.google.com/
# 2. Enable 2-Step Verification (Security → 2-Step Verification)
# 3. Generate App Password (Security → 2-Step Verification → App passwords)
# 4. Copy the 16-character password and paste below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Store email (sender)
STORE_EMAIL=your-pharmacy@gmail.com
STORE_NAME=AI Pharmacy

# Owner email (recipient for notifications)
OWNER_EMAIL=owner@gmail.com

# ===== MongoDB Connection (if not already set) =====
# MONGO_URI=mongodb://localhost:27017/pharmacy

# ===== JWT Secret (if not already set) =====
# JWT_SECRET=your-secret-key-here

# ===== Server Port (if not already set) =====
# PORT=3000
